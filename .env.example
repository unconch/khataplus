# KhataPlus Environment Variables Example
# Copy this file to .env.local and fill in the values

# Database (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Supabase (optional legacy scripts)
NEXT_PUBLIC_SUPABASE_URL=
# Example (direct): https://your-project-ref.supabase.co
# Example (proxy): https://your-worker.yourdomain.workers.dev
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (Required for secure data storage)
# Generate a 64-character hex string
ENCRYPTION_KEY=

# Redis (Upstash) - For caching
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth0 Authentication
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Paddle Billing
PADDLE_API_KEY=
PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox
PADDLE_PRICE_KEEP_MONTHLY=
PADDLE_PRICE_KEEP_YEARLY=
PADDLE_PRICE_STARTER_MONTHLY=
PADDLE_PRICE_STARTER_YEARLY=
PADDLE_PRICE_PRO_MONTHLY=
PADDLE_PRICE_PRO_YEARLY=
PADDLE_PRICE_BUSINESS_MONTHLY=
PADDLE_PRICE_BUSINESS_YEARLY=

# Cashfree Billing
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
NEXT_PUBLIC_CASHFREE_ENV=sandbox
# Optional but recommended for payment return redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo / Guest Mode (Optional)
# DEMO_DATABASE_URL=
# NEXT_PUBLIC_CONVEX_URL=

# Sentry Monitoring (Optional but recommended in production)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENABLE_BUILD=false
SENTRY_ENABLE_VERCEL_MONITORS=false

# Build Controls (Optional)
# NEXT_ENABLE_TYPECHECK=true
# NEXT_DISABLE_TYPECHECK=false
